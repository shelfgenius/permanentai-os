FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    ffmpeg tesseract-ocr tesseract-ocr-ron tesseract-ocr-eng \
    libgl1-mesa-glx libglib2.0-0 curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements_media.txt ./
RUN pip install --no-cache-dir -r requirements_media.txt

COPY . .

CMD ["python", "-m", "services.media_pipeline_runner"]
