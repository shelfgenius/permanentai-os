# ============================================================
# TechQuery — Environment Configuration
# Copy this file to backend/.env and fill in the values.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=TechQuery Backend
APP_VERSION=1.0.0
DEBUG=false

# ── PostgreSQL ───────────────────────────────────────────────
# Requires pg_vector extension: https://github.com/pgvector/pgvector
DATABASE_URL=postgresql+asyncpg://techquery:password@localhost:5432/techquery
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Embeddings ───────────────────────────────────────────────
# all-MiniLM-L6-v2 (384d, fast) or all-mpnet-base-v2 (768d, higher quality)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

# ── LLM Provider ─────────────────────────────────────────────
# Options: openai | anthropic | ollama
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Ollama (local, no API key required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── RAG Parameters ───────────────────────────────────────────
RAG_TOP_K_SEMANTIC=6
RAG_TOP_K_KEYWORD=6
RAG_RRF_K=60
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_MAX_CONTEXT_TOKENS=3000

# ── Storage ──────────────────────────────────────────────────
# Options: minio | s3
STORAGE_BACKEND=minio

# MinIO (self-hosted, default)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=techquery-assets
MINIO_SECURE=false

# AWS S3 (alternative)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=techquery-assets

# ── Auth ──────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# ── Supabase ──────────────────────────────────────────────────
# Anon (publishable) key — safe for frontend; RLS policies enforce security.
SUPABASE_ANON_KEY=

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ──────────────────────────────────────────────────────────────
#  auto_tunnel.py — tunnel URL publisher
# ──────────────────────────────────────────────────────────────
# Primary publisher: Supabase Realtime (recommended)
SUPABASE_URL=https://mpzvaicxzbnfocytwpxk.supabase.co
# SERVICE ROLE KEY — KEEP SECRET, local-only. Never ship to frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ── TTS (Text-to-Speech) ────────────────────────────────────
# ElevenLabs (primary, paid)
ELEVENLABS_API_KEY=
# XTTS v2 — local voice-cloning TTS (pip install TTS)
# Point to a short reference .wav of the target speaker voice
XTTS_SPEAKER_WAV=
# Language code: en, ro, es, fr, de, it, pt, pl, tr, ru, nl, cs, ar, zh-cn, ja, ko, hu
XTTS_LANGUAGE=en

# Fallback publisher: Cloudflare Worker KV registry (already deployed)
CF_TUNNEL_WORKER_URL=https://pai-tunnel-registry.maherboss23.workers.dev
CF_TUNNEL_TOKEN=GENERATE_A_RANDOM_TOKEN_HERE

# Last-resort publisher: email the URL every time the tunnel opens.
# Leave TUNNEL_EMAIL_TO blank to disable.
TUNNEL_EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
