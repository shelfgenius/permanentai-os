{
  "name": "techquery-desktop",
  "version": "1.0.0",
  "description": "Standalone desktop application for technical queries — maritime, electrical, construction, DIY, 3D modeling and more.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev:backend": "cd backend && uvicorn main:app --reload --port 8000",
    "build": "cd frontend && npm run build && cd .. && electron-builder build",
    "deploy": "powershell -ExecutionPolicy Bypass -File push.ps1",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": ["electron", "react", "fastapi", "rag", "technical", "desktop"],
  "author": "TechQuery",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "axios": "^1.6.5"
  },
  "build": {
    "appId": "com.techquery.desktop",
    "productName": "TechQuery",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "backend/**/*",
      "!backend/__pycache__/**",
      "!backend/*.pyc"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*", "!__pycache__/**", "!*.pyc"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "frontend/public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "frontend/public/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "frontend/public/icon.png"
    }
  }
}
