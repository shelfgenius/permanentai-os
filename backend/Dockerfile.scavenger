FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    curl wget ffmpeg chromium chromium-driver \
    && rm -rf /var/lib/apt/lists/*

ENV CHROME_BIN=/usr/bin/chromium
ENV CHROMEDRIVER_PATH=/usr/bin/chromedriver

COPY requirements_scavenger.txt ./
RUN pip install --no-cache-dir -r requirements_scavenger.txt

COPY . .

CMD ["python", "-m", "agents.scavenger_runner"]
